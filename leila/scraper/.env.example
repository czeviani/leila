SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Anthropic API — usada no enriquecimento IA batch (Camada 2, Haiku)
# Se não configurado, o enriquecimento IA é pulado; apenas heurística roda.
ANTHROPIC_API_KEY=sk-ant-...

# Proxy rotation — IPs brasileiros (obrigatório para Caixa Econômica em produção)
# Formato: ip:porta:usuario:senha,ip:porta:usuario:senha,...
PROXY_LIST=
PROXY_ROTATION=false

# User agent para requisições
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
